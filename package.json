{
  "name": "monorepo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "turbo run format",
    "prepare": "husky",
    "lang:create": "npm run lang:create --workspace=web",
    "lang:update": "npm run lang:update --workspace=web",
    "lang:delete": "npm run lang:delete --workspace=web",
    "lang:add": "npm run lang:add --workspace=web",
    "lang:remove": "npm run lang:remove --workspace=web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "npm run lint --workspace=web -- --fix",
      "prettier --write"
    ],
    "apps/api/**/*.cs": [
      "dotnet format apps/api/Api.Web/Api.Web.csproj --include"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.6"
  }
}
